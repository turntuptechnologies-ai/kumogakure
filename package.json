{
  "name": "kumogakure",
  "version": "0.0.0",
  "description": "A serverless low-interaction web honeypot for Cloudflare Workers.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "types": "wrangler types --strict-vars=false",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "migrations:apply": "wrangler d1 migrations apply kumogakure",
    "reset:data": "bash scripts/reset-data.sh",
    "gaps": "bash scripts/find-gaps.sh",
    "stats": "bash scripts/stats.sh",
    "quota": "bash scripts/quota.sh"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "hono": "^4.12.18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cloudflare/vitest-pool-workers": "^0.16.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.90.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  }
}
